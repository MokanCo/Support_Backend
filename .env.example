# On Render, use your HTTPS frontend URL (invite/login links + email logo/beans):
# FRONTEND_URL=https://your-app.onrender.com
# Optional: separate CDN for email images (defaults to FRONTEND_URL)
# EMAIL_ASSETS_URL=https://your-app.onrender.com
# Optional: links in completion emails (falls back to FRONTEND_URL)
# APP_URL=https://your-app.onrender.com
# Optional: OpenAPI server URL in Swagger (defaults to http://localhost:$PORT)
